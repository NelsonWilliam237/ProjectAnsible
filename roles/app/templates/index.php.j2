<?php
$host     = '{{ mysql_db_host }}';
$dbname   = '{{ mysql_db_name }}';
$username = '{{ mysql_db_user }}';
$password = '{{ vault_mysql_db_password }}';

$connected = false;
try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname", $username, $password);
    $connected = true;
} catch (Exception $e) {
    $error = $e->getMessage();
}
?>
